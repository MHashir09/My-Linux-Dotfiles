{
  "niri/workspaces": {
    "format": "{index}",
  },

  "niri/window": {
    "format":"{title} ",
    "icon": true,
    "icon-size": 18,
    "tooltip": false,
    "separate-outputs": true
  },

  "clock": {
    "format": "{:%I:%M %p %a %d} ΎΑΩ ",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "interval": 60,
    "calendar": {
        "mode": "year",
        "mode-mon-col": 3,
        "weeks-pos": "right",
        "on-scroll": 1,
    },
    "actions": {
        "on-click-right": "mode",
        "on-scroll-up": "shift_up",
        "on-scroll-down": "shift_down",
     },
  },

  "battery": {
    "states": {
      "idle": 40,
      "warning": 20,
      "critical": 1,
    },
    "format": "{icon}",
    "format-charging": "≤░ΓΕ",
    "format-plugged": "≤░γξ",
    "tooltip-format": "{capacity}%",
    "format-icons": ["≤░Β╗", "≤░Β╜", "≤░Β╛", "≤░ΓΓ", "≤░Β╣"],
    "interval": 60,
    "on-click": "~/.config/rofi/scripts/rofi-battery-power-menu.sh"
  },

  "network": {
    "format": "ΎΘτ",
    "format-wifi": "ΎΘτ",
    "format-ethernet": "≤░ΙΒ",
    "format-disconnected": "≤░Ψς",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "{ifname}",
    "tooltip-format-disconnected": "Disconnected",
    "on-click": "~/.config/rofi/scripts/rofi-wifi-menu.sh"
  },

  "pulseaudio": {
    "format": "{icon}",
    "format-muted": "≤░ΨΒ",
    "tooltip-format": "{volume}%",
    "format-icons": {
        "default": ["≤░ζθ","≤░Χ┐","ΎΑπ","ΎΑρ"],
    },
    "on-click": "~/.config/rofi/scripts/rofi-volume-selector.sh",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%"
  },

  "custom/system-info": {
    "format": "ΌψΗ",
    "exec": "echo '{\"tooltip\":\"'$(source /etc/os-release && echo $PRETTY_NAME)'\"}'",
    "return-type": "json",
    "interval": "once",
    "on-click": "kitty --class floating-fastfetch sh -c 'tput civis; fastfetch; sleep infinity'"
  },

  "memory": {
    "format": "≤▒Σ╛ ",
    "tooltip-format": "{used:.1f}/{total:.1f} GB",
    "interval": 5,
    "on-click": "kitty btop"
  },

 "backlight": {
    "format": "{icon}",
    "device": "intel_backlight",
    "tooltip-format": "{percent}%",
    "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"],
    "on-scroll-down": "brightnessctl -c backlight set 5%-",
    "on-scroll-up": "brightnessctl -c backlight set +5%",
    "on-click": "~/.config/rofi/scripts/rofi-brightness-selector.sh"
  },

 "custom/notification": {
    "format": "≤░Γγ",
    "tooltip": true,
    "tooltip-format": "Open Notification Settings",
    "on-click": "~/.config/rofi/scripts/rofi-notification-menu.sh"
  },

  "custom/power": {
    "format": "έΠ╗",
    "on-click": "~/.config/rofi/scripts/rofi-powermenu.sh",
    "tooltip-format": "Power Menu",
  },

  "custom/launcher": {
    "format": "ΎΑΧ",
    "on-click": "rofi -show codeverse -modi 'codeverse:~/.config/rofi/scripts/main-menu.sh'",
    "tooltip-format": "Main Menu",
  }
}
